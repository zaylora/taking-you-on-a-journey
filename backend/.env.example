# 复制为 .env 后填值。.env 必须保存为「无 BOM 的 UTF-8」。
# 字段名大小写不敏感（pydantic-settings）。

# === LLM Provider（默认 openai）===
LLM_PROVIDER=openai

# --- OpenAI（默认 provider，M1 验收需要）---
OPENAI_API_KEY=
# 自定义中转地址（可选）。注意：环境变量 OPENAI_API_BASE 优先级高于 OPENAI_BASE_URL，二选一别同设。
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic（可选，工厂默认不使用；切换时设 LLM_PROVIDER=anthropic）---
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# 采样温度
TEMPERATURE=0.0

# 前端直连放行的源（JSON 数组；默认已含 Vite 5173，通常无需设置）
# CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
